<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>TheSeniorGuru</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>TheSeniorGuru</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>GoogleMapsApiKey</key>
	<string>$(GOOGLE_MAPS_API_KEY)</string>
	<key>NSHealthShareUsageDescription</key>
	<string>TheSeniorGuru reads approved Apple Health and wearable data to update daily wellness, safety, and caregiver guidance.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>TheSeniorGuru may write approved wellness records only when you explicitly allow it.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TheSeniorGuru uses location to check safe zones, estimate transportation, and find nearby senior-friendly services.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>TheSeniorGuru uses your location to monitor safe zones and alert your care circle if you leave a designated area.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>TheSeniorGuru uses background location to keep your care circle informed of your safety.</string>
	<key>NSLocationTemporaryUsageDescriptionDictionary</key>
	<dict>
		<key>SafetyPreciseLocation</key>
		<string>Precise location lets TheSeniorGuru pinpoint your safe zone status accurately on the map.</string>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>TheSeniorGuru uses your camera to capture photos for your profile and onboarding verification.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>TheSeniorGuru accesses your photo library so you can select profile photos and share memories with your care circle.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>TheSeniorGuru saves captured photos to your photo library.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>TheSeniorGuru uses the microphone for voice check-ins and Guru voice commands.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>TheSeniorGuru uses speech recognition to turn your voice into text for Guru and chat.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
